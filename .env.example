# ============================================
# 上岸引擎（Anan Engine）环境变量配置
# ============================================
# 复制此文件为 .env 并填入实际值：
#   cp .env.example .env

# ---------- Supabase（必须） ----------
# 从 Supabase Dashboard → Settings → API 获取
COZE_SUPABASE_URL=https://your-project-id.supabase.co
COZE_SUPABASE_ANON_KEY=your-anon-key-here
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ---------- 服务端口（可选） ----------
# 默认 5000，云部署时由平台自动注入
DEPLOY_RUN_PORT=5000
